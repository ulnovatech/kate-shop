# Kate shop — copy to .env and fill in values from Supabase Dashboard → Project Settings → API
# Never commit .env. Never put SUPABASE_SERVICE_ROLE_KEY in VITE_* variables.

# --- Client (Vite / browser) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

# --- Server (SSR / Nitro — same project, same public key) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key

# --- Server only (Dashboard → API → service_role secret). Required for admin server ops & migration scripts. ---
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# --- Required for `npm run db:chunk3` / `npm run db:migrate` (Dashboard → Database → Connection string → URI) ---
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- Chunk 4: first-time admin setup (server only) ---
# Optional: require a secret token on /admin/setup (recommended in production)
# BOOTSTRAP_TOKEN=your-long-random-setup-token
# Public site URL for invite links (defaults to http://localhost:5173 — see vite.config.ts)
# APP_ORIGIN=http://localhost:5173

# --- Local dev (npm run dev starts all three) ---
# Storefront:  http://localhost:5173  (@kate/storefront)
# Admin app:   http://localhost:5174  (@kate/admin)
# Monolith:    http://localhost:5175  (shop + /admin — DEV_MONOLITH_PORT)
# DEV_MONOLITH_PORT=5175

# --- Kate Admin app (blueprint C1+ — staff subdomain + APK) ---
# Staff web origin (production: https://admin.yourdomain.com)
# ADMIN_ORIGIN=http://localhost:5174
# Baked into admin client build / Capacitor (same value as ADMIN_ORIGIN)
# VITE_ADMIN_ORIGIN=http://localhost:5174
# Storefront URL for “View shop” from the standalone admin app (C3)
# VITE_APP_ORIGIN=http://localhost:5173
# Optional second Cloudflare Worker name for admin deploy (C6)
# CLOUDFLARE_ADMIN_WORKER_NAME=kate-admin
# Optional zone for automatic wrangler routes (shop + admin hostnames)
# CLOUDFLARE_ZONE_NAME=yourdomain.com

# --- Kate Admin APK (C7) — Capacitor server URL override ---
# Emulator + npm run dev:admin on host: http://10.0.2.2:5174
# ADMIN_MOBILE_SERVER_URL=http://10.0.2.2:5174
# Supabase redirect for APK auth (C8): com.kate.admin://login-callback

# --- Kate Admin APK release signing (C11 — local or CI secrets, never commit) ---
# ANDROID_KEYSTORE_BASE64=...
# ANDROID_KEYSTORE_PASSWORD=...
# ANDROID_KEY_ALIAS=kate-admin
# ANDROID_KEY_PASSWORD=...
# KATE_RELEASE_VERSION=1.0.0

# --- Kate Admin staff push (C12 — silent until configured) ---
# STAFF_PUSH_ENABLED=true
# FCM_SERVER_KEY=your_fcm_server_key
# Firebase: apps/admin-mobile/android/app/google-services.json (from Firebase Console)

# --- Kate Admin Play Store (C12 — future distribution) ---
# BUILD_ADMIN_AAB=true   # GitHub Actions: also build signed release AAB

# --- Chunk 16: Playwright E2E (optional — uses your dev/staging Supabase project) ---
# E2E_ADMIN_EMAIL=owner@example.com
# E2E_ADMIN_PIN=123456
# E2E_STAFF_FORGOT_PIN_CODE=123456   # optional — manual forgot-PIN E2E (destructive)
# E2E_STAFF_NEW_PIN=654321           # optional — pair with E2E_STAFF_FORGOT_PIN_CODE
# E2E_BASE_URL=http://localhost:5173
# E2E_ADMIN_BASE_URL=http://localhost:5174   # apps/admin (default for admin E2E project)

# --- Chunk 17: Cloudflare deploy (local npm run deploy or GitHub Actions) ---
# CLOUDFLARE_API_TOKEN=your_workers_edit_token
# CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
# CLOUDFLARE_WORKER_NAME=kate-shop

# --- Chunk 18: Observability (no new vars — uses Supabase keys above) ---
# Health: GET /health.json — see docs/OBSERVABILITY.md

# --- Customer OTP SMS (optional — silent until configured) ---
# SMS_OTP_PROVIDER=noop
# SMS_OTP_PROVIDER=africas_talking
# AFRICAS_TALKING_USERNAME=sandbox
# AFRICAS_TALKING_API_KEY=your_api_key
# AFRICAS_TALKING_SENDER_ID=KATESHOP
# SMS_OTP_PROVIDER=wesendall
# WESENDALL_API_KEY=sk_live_...
# WESENDALL_API_SECRET=...
# WESENDALL_WALLET_ID=...
# SMS_OTP_PROVIDER=egosms
# EGOSMS_USERNAME=...
# EGOSMS_PASSWORD=...
# EGOSMS_SENDER_ID=KATESHOP
# SMS_OTP_DEV_ECHO=1

# --- Staff Google OAuth (setup + invite signup). Off unless explicitly enabled. ---
# VITE_STAFF_GOOGLE_AUTH_ENABLED=true
# STAFF_GOOGLE_AUTH_ENABLED=true

# --- Staff onboarding (invite links + signup email OTP). Off by default = simple install + email/PIN signup. ---
# Set both client and server flags to true when reactivating invite-only onboarding.
# VITE_STAFF_INVITE_FLOW_ENABLED=true
# STAFF_INVITE_FLOW_ENABLED=true
# VITE_STAFF_SIGNUP_EMAIL_OTP_REQUIRED=true

# --- Staff auth (login / signup / PIN). Off by default = open admin entry with role links. ---
# Set both to true to restore gated sign-in.
# VITE_STAFF_AUTH_REQUIRED=true
# STAFF_AUTH_REQUIRED=true

# --- Staff email OTP (auth chunk 18 — Gmail passcodes for signup / forgot PIN) ---
# EMAIL_OTP_PROVIDER=noop
# EMAIL_OTP_PROVIDER=gmail
# EMAIL_OTP_PROVIDER=console
# GMAIL_USER=your-bot@gmail.com
# GMAIL_APP_PASSWORD=your_google_app_password

# --- Admin mobile one-click publish (server only — GitHub Actions workflow_dispatch) ---
# GITHUB_REPO=ulnovatech/kate-shop
# KATE_GH_RELEASE_TOKEN=ghp_...   # fine-grained PAT: Actions Read+Write on repo (GitHub secret name; not GITHUB_*)

# --- Staff PIN ops (one-time — set in .env, run npm run staff:set-owner-pin) ---
# STAFF_OWNER_INITIAL_PIN=12345

# --- Staff screen lock (optional; off by default — sign in once, stay signed in until manual sign out) ---
# VITE_STAFF_SCREEN_LOCK_ENABLED=true
# VITE_STAFF_SCREEN_LOCK_IDLE_MS=300000
